#!/bin/sh
alias clr="clear" \
      h="cd ~ && clr" \
      u="sudo apt-get update" \
      v="$EDITOR" \
      f="$BROWSER" \
      i3c="$EDITOR ~/.config/i3/config" \
      i3b="$EDITOR ~/.config/i3blocks/config" \
      brc="$EDITOR ~/.bashrc" \
      brca="$EDITOR ~/.bash_aliases" \
      g="git" \
      gac="g add . && g commit" \
      gp="git push" \
      img="sxiv" \
      pdf="zathura" \
      z="zathura" \
      pa="ffplay -loglevel quiet -showmode 1" \
      pv="ffplay -loglevel quiet" \
      :q="exit" \
      ls="ls -hN --group-directories-first --color=auto" \
      lsa="ls -A" \
      grep="grep --color=auto" \
      mkd="mkdir -pv" \
      rmf="rm -rf" \

