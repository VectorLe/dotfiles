alias clr="clear" \
      h="cd ~ && clr" \
      v="$EDITOR" \
      f="$BROWSER" \
      i3c="$EDITOR ~/.config/i3/config" \
      i3sc="$EDITOR ~/.config/i3status/config" \
      brc="$EDITOR ~/.bashrc" \
      brca="$EDITOR ~/.bash_aliases" \
      g="git" \
      img="sxiv" \
      pdf="zathura" \
      z="zathura" \
      p="ffplay -loglevel quiet -showmode 1" \
      :q="exit" \
      ls="ls -hN --group-directories-first --color=auto" \
      lsa="ls -A" \
      grep="grep --color=auto" \
      mkd="mkdir -pv" \
      rmf="rm -rf" 

