alias i3c="$EDITOR ~/.config/i3/config" \
      i3sc="$EDITOR ~/.config/i3status/config" \
      brc="$EDITOR ~/.bashrc" \
      brca="$EDITOR ~/.bash_aliases" \
      clr="clear" \
      img="sxiv" \
      pdf="zathura" \
      ls="ls --color=auto" \
      grep="grep --color=auto" \
      mkd="mkdir -pv" \
      rmf="rm -rf" 

