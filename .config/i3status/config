general {
    interval       = 1
    colors         = true
    color_good     = "#46eb96"
    color_degraded = "#ff7832"
    color_bad      = "#ff367b"
}

order += "wireless _first_"
order += "battery all"
order += "volume master"
order += "tztime local"

wireless _first_ {
    format_up   = "WiFi on 🛰"
    format_down = "WiFi off ❌"
    separator_block_width = 20
}

battery all {
    format       = "%status %percentage %remaining"
    format_down  = "No battery"
    status_chr   = "🔌"
    status_bat   = "🔋"
    status_full  = "⚡"
    hide_seconds = true
    low_threshold            = 30
    threshold_type           = time
    last_full_capacity       = true
    integer_battery_capacity = true
    separator_block_width    = 20 
}

volume master {
    format       = "Vol 🔊: %volume"
    format_muted = "Vol 🔇: mute %volume"
    device       = "default"
    mixer        = "Master"
    mixer_idx    = 0
    separator_block_width = 20
}

tztime local {
    format = "📅 %a %m/%d/%Y 🕓 %I:%M:%S %p"
    separator_block_width = 20
}

